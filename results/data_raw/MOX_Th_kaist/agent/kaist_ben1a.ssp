% ----------  asy_mox1z  :  MOX-1 with 3 Pu-enrichment zones  ----
%  Peripheral  (4.3 w/o Pu-tot) : outer 2 rings + instrument tube row/col
%  Intermediate (7.0 w/o Pu-tot) : 1-ring  around the central 3x3
%  Central     (8.7 w/o Pu-tot) : central 3x3 (excluding the
%                                 instrument tube at the center)
%
%  17x17 lattice, instrument tube at (8,8), 24 guide tubes in the
%  standard 4-cluster pattern.
lat asy_mox1z  1   17  17  1.2600
fuel_mox1_p fuel_mox1_p fuel_mox1_p fuel_mox1_p fuel_mox1_p fuel_mox1_p fuel_mox1_p fuel_mox1_p fuel_mox1_p fuel_mox1_p fuel_mox1_p fuel_mox1_p fuel_mox1_p fuel_mox1_p fuel_mox1_p fuel_mox1_p fuel_mox1_p
