%==================================================================
%            1/4 CORE LATTICE  (4 x 4, reflective BC)
%==================================================================
%  1/4 core with the corner of the full core at (0,0).  The lattice
%  is 4x4 with pitch 21.42 cm.  The 13 fueled cells form a staircase
%  pattern, with the 3 outer-corner cells (row 0, cols 2-3) being
%  reflector (universe 0 = water outside the lattice).
%
%  Cells are listed from the +y outermost row (row 0 in the lattice)
%  to the corner of the full core (row 3 = y=0).
%
%  Reading the KAIST benchmark 1/4-core diagram (PDF page 1), the
%  assembly types are, in row 0..3 order (top to bottom in the PDF
%  = outermost to innermost in the full core):
%
%  row 0 (outermost, 2 cells) :  UOX-1   UOX-1
%  row 1 (3 cells)            :  MOX-1   UOX-2   UOX-1
%  row 2 (4 cells)            :  UOX-2   MOX-1(BA8)   UOX-2   UOX-1
%  row 3 (innermost = corner of full core, 4 cells) :
%                                UOX-2(BA16)   UOX-2   MOX-1   UOX-1
%
%  The "(CR)" cells in the diagram mark UOX-2 assemblies that have a
%  control-rod cluster in the ARI case; the geometry is otherwise
%  identical.  For the ARO (default) case the 24 guide tubes are
%  water-filled; for the ARI case they contain B4C rods.
%==================================================================
%  Origin (0, 0, 0) places the lattice corner at the geometric origin,
%  which is the symmetry-corner of the full core.
lat coreLat  1  4  4  21.4200  0.0  0.0  0.0
asy_uox1   asy_uox1   0          0
asy_mox1z  asy_uox2   asy_uox1   0
asy_uox2   asy_mox1z_ba8  asy_uox2   asy_uox1
asy_uox2gd asy_uox2   asy_mox1z  asy_uox1


%==================================================================
%                       SURFACES
%==================================================================
%  1/4 core square boundary (origin at the lattice corner = corner
%  of the full core;  side = 4 * 21.42 = 85.68 cm)
surf sX0      px        0.0000
surf sX1      px       85.6800
surf sY0      py        0.0000
surf sY1      py       85.6800
surf sX2      px       88.2000          % outer surface of the baffle
surf sY2      py       88.2000
surf sX3      px      104.1000          % outer surface of the reflector
surf sY3      py      104.1000

% Axial surfaces (active core is centered at z=0)
surf pzBot    pz      -182.8800         % active-fuel bottom
surf pzTop    pz       182.8800         % active-fuel top
surf pzReflB  pz      -204.3000         % bottom of bottom reflector
surf pzReflT  pz       204.3000         % top of top reflector


%==================================================================
%                          CELLS
%==================================================================
%  1/4 core cell - filled with the coreLat lattice.
%  The lattice is positioned in the +x, +y region (corner of the
%  full core is at x=0, y=0).  The 3 "0" cells in the lattice are
%  void (universe 0) and are filled with the surrounding reflector
%  water (cool) by the cell evaluator.
cell cCore   coreLat   -sX1   sX0   -sY1   sY0   -pzTop  pzBot  fill coreLat  -1

%  Stainless-steel baffle (2.52 cm thick) around the core.
%  In the 1/4 model the baffle forms an L-shape in the +x, +y region,
%  which we split into 3 cells (one for the +x side, one for the
%  +y side, one for the outer corner).
cell cBafX   baffle     sX1   -sX2   sY0   -sY1    pzBot  -pzTop
cell cBafY   baffle     sX0   -sX1   sY1   -sY2    pzBot  -pzTop
cell cBafC   baffle     sX1   -sX2   sY1   -sY2    pzBot  -pzTop

%  Outer reflector (water, 18.9 cm thick = from sX2=88.20 to sX3=104.10)
cell cRefl   cool      -sX3   sX0   -sY3   sY0    pzBot  -pzTop

%  Axial reflectors (top and bottom of the active core)
cell cReflB  cool      -sX3   sX0   -sY3   sY0    pzBot  -pzReflB
cell cReflT  cool      -sX3   sX0   -sY3   sY0    pzReflT -pzTop

%  Outside world
cell cOut    outside    sX3   -sX3   sY3   -sY3   pzReflB -pzReflT


%==================================================================
%                     DETECTORS / OUTPUT
%==================================================================
%  Pin-power distribution detector  (axial-uniform, x-y plane)
det pDetPin   dr  -8 void  fuel_uox1 fuel_uox2 fuel_mox1_p fuel_mox1_i fuel_mox1_c fuel_gd b4c
     du  0.0  dv  0.0
     dx  200  dy  200

%  Assembly-power detector (radial, 1/4 core)
det pDetAsy   dr  -8 void
     du  0.0  dv  0.0
     dx  4    dy  4

%  Energy spectrum detector
det pDetE     dr  -2 void fuel_uox1 fuel_uox2 fuel_mox1_p fuel_mox1_i fuel_mox1_c fuel_gd b4c cool
     de  100  dg  500


%==================================================================
%                       PLOT OUTPUT
%==================================================================
%  XY plot of the core
plot 1  2000  2000  0.0
plot 2  2000  2000  0.0
plot 3  2000  2000  182.8800


%==================================================================
%                      RUN CALCULATION
%==================================================================
%  Run the input from a terminal with:
%     sss2 -omp 8 kaist_ben1a.ssp
%==================================================================
